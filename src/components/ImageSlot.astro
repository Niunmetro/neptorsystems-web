---
/* Photo slot. With `name`, renders a responsive <picture> (AVIF/WebP/JPG + srcset)
   from /assets/photos/<name>-<w>.<fmt>. Without it, an on-brand aqua placeholder
   ([PENDIENTE-FOTOS]). Alt text is exact per language (set by the caller). */
interface Props {
  alt: string;
  name?: string;      // 'hero' | 'origin' — base of the generated photo set
  priority?: boolean; // hero -> eager + fetchpriority high
  radius?: string;
  sizes?: string;     // responsive sizes attribute
}
const { alt, name, priority = false, radius = '0', sizes = '100vw' } = Astro.props;
const widths = [640, 960, 1280, 1600];
const srcset = (fmt: string) =>
  widths.map((w) => `/assets/photos/${name}-${w}.${fmt} ${w}w`).join(', ');
const imgStyle = `width:100%;height:100%;object-fit:cover;border-radius:${radius};display:block;`;
---
{name ? (
  <picture>
    <source type="image/avif" srcset={srcset('avif')} sizes={sizes} />
    <source type="image/webp" srcset={srcset('webp')} sizes={sizes} />
    <img
      src={`/assets/photos/${name}-1280.jpg`}
      srcset={srcset('jpg')}
      sizes={sizes}
      alt={alt}
      width="1280" height="960"
      loading={priority ? 'eager' : 'lazy'}
      fetchpriority={priority ? 'high' : 'auto'}
      decoding="async"
      style={imgStyle}
    />
  </picture>
) : (
  <div
    role="img"
    aria-label={alt}
    style={`position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:linear-gradient(140deg,var(--aqua-100) 0%,var(--aqua-050) 55%,#fff 120%);border-radius:${radius};`}
  >
    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--aqua-500)" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="opacity:0.7;">
      <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z" />
    </svg>
  </div>
)}
