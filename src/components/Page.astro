            <input type="text" name="company" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;" />
            <div class="checkbox-row">
              <input id="wl-consent" class="checkbox" type="checkbox" name="consent" required={WAITLIST_ENABLED} />
              <label for="wl-consent" style="font-family:var(--font-body);font-size:13.5px;line-height:1.55;color:var(--ink-500);">{t.consent1}<a href={legal.privacy} style="color:var(--aqua-700);text-decoration:underline;text-underline-offset:2px;">{t.consentLink}</a>{t.consent2}</label>
            </div>
            {WAITLIST_ENABLED ? (
              <button type="submit" class="btn btn--gold btn--lg btn--block">{t.ctaJoinForm}</button>
            ) : (
              <a class="btn btn--gold btn--lg btn--block" href={waitlistMailto}>{t.ctaJoinForm}</a>
            )}
          </form>
        </div>
        <div style="background:var(--navy-800);background-image:radial-gradient(90% 80% at 85% -10%, rgba(0,194,209,0.16) 0%, rgba(0,194,209,0) 55%);border-radius:22px;padding:clamp(30px,4.5vw,52px);display:flex;flex-direction:column;position:relative;overflow:hidden;">
          <svg aria-hidden="true" viewBox="0 0 400 30" preserveAspectRatio="none" style="position:absolute;bottom:10px;left:0;width:100%;height:22px;opacity:0.3;"><path d="M0,15 C50,5 100,5 150,15 S250,25 300,15 S380,6 400,12" fill="none" stroke="var(--aqua-300)" stroke-width="1.5" vector-effect="non-scaling-stroke"/></svg>
          <div style="font-family:var(--font-ui);font-size:12px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:var(--aqua-300);">{t.ecoKicker}</div>
          <h3 style="font-family:var(--font-heading);font-weight:600;font-size:clamp(1.45rem,2.5vw,1.85rem);line-height:1.18;letter-spacing:-0.01em;color:#fff;margin:14px 0 0;text-wrap:balance;">{t.ecoH3}</h3>
          <p style="font-family:var(--font-body);font-size:16px;line-height:1.68;color:rgba(255,255,255,0.76);margin:18px 0 0;text-wrap:pretty;">{t.ecoText}</p>
          <div style="margin-top:auto;padding-top:30px;">
            <a class="btn btn--secondary btn--on-dark btn--lg" href={mailto}>{t.ctaWrite}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  </main>

  <div aria-hidden="true" style="background:#fff;line-height:0;"><svg viewBox="0 0 1440 44" preserveAspectRatio="none" style="display:block;width:100%;height:44px;"><path d="M0,24 C120,8 240,8 360,24 S600,40 720,24 S960,8 1080,24 S1320,40 1440,24" fill="none" stroke="var(--aqua-500)" stroke-width="1.5" vector-effect="non-scaling-stroke" opacity="0.6"/><path d="M0,32 C140,16 280,16 420,32 S700,46 840,30 S1120,12 1260,26 S1400,38 1440,34" fill="none" stroke="var(--aqua-300)" stroke-width="1" vector-effect="non-scaling-stroke" opacity="0.45"/></svg></div>

  <!-- ============ S11 · FOOTER ============ -->
  <footer style="background:var(--navy-900);color:#fff;">
    <div style="max-width:1220px;margin:0 auto;padding:clamp(56px,7vw,80px) clamp(20px,5vw,40px) 44px;">
      <div style="display:flex;flex-wrap:wrap;justify-content:space-between;gap:36px;">
        <div style="max-width:380px;">
          <img src="/assets/logo-neptor-white.png" alt="Neptor Systems" width="150" height="36" style="height:36px;width:auto;display:block;" />
          <p style="font-family:var(--font-body);font-size:14px;line-height:1.65;color:rgba(255,255,255,0.58);margin:20px 0 0;">{t.ftCompany}</p>
        </div>
        <div style="display:flex;flex-direction:column;gap:10px;">
          <a href={mailto} style="font-family:var(--font-ui);font-size:15px;color:rgba(255,255,255,0.85);">{ORG.email}</a>
          <a href={`tel:${ORG.phoneHref}`} style="font-family:var(--font-ui);font-size:15px;color:rgba(255,255,255,0.85);">{ORG.phone}</a>
          <div style="display:flex;flex-wrap:wrap;gap:8px 16px;margin-top:10px;">
            <a href={legal.legal} style="font-family:var(--font-ui);font-size:14px;color:rgba(255,255,255,0.58);">{t.ftLegal}</a>
            <span style="color:rgba(255,255,255,0.25);">·</span>
            <a href={legal.privacy} style="font-family:var(--font-ui);font-size:14px;color:rgba(255,255,255,0.58);">{t.ftPrivacy}</a>
            <span style="color:rgba(255,255,255,0.25);">·</span>
            <a href={legal.cookies} style="font-family:var(--font-ui);font-size:14px;color:rgba(255,255,255,0.58);">{t.ftCookies}</a>
          </div>
        </div>
      </div>
      <div style="height:1px;background:rgba(255,255,255,0.12);margin:40px 0 26px;"></div>
      <div style="display:flex;flex-wrap:wrap;justify-content:space-between;gap:16px;align-items:baseline;">
        <p style="font-family:var(--font-body);font-size:13.5px;line-height:1.6;color:rgba(255,255,255,0.58);margin:0;max-width:620px;">{t.disclaimer}</p>
        <p style="font-family:var(--font-ui);font-size:13px;color:rgba(255,255,255,0.4);margin:0;">© 2026 Neptor Systems SL</p>
      </div>
    </div>
  </footer>

</div>
