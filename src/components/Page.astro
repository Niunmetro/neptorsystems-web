---
import { dict, type Lang } from '../i18n/copy';
import { ALT, LEGAL, WAITLIST_ENABLED, ORIGIN_VIDEO_ENABLED, FORM_ENDPOINT, ORG } from '../config';
import ImageSlot from './ImageSlot.astro';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = dict[lang];

const legal = LEGAL[lang];
const mailto = `mailto:${ORG.email}`;
const waitlistSubject = lang === 'es' ? 'Lista de espera Neptor' : 'Neptor waitlist';
const waitlistMailto = `mailto:${ORG.email}?subject=${encodeURIComponent(waitlistSubject)}`;

// Photo alt text (exact, per language — brief §4)
const heroAlt = lang === 'es'
  ? 'Niño jugando en una piscina bajo la supervisión de un adulto.'
  : 'Child playing in a pool under adult supervision.';
const originAlt = lang === 'es'
  ? 'Taller de prototipado con impresora 3D y electrónica.'
  : 'Prototyping workshop with a 3D printer and electronics.';
---
<a class="skip-link" href="#main">{lang === 'es' ? 'Saltar al contenido' : 'Skip to content'}</a>

<div id="top" data-page style="font-family:var(--font-body);color:var(--ink-700);background:#fff;overflow-x:clip;">

  <!-- ============ NAV ============ -->
  <header data-header style="position:fixed;top:0;left:0;right:0;z-index:60;background:rgba(6,21,47,0.35);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border-bottom:1px solid rgba(255,255,255,0.10);transition:background .3s ease,box-shadow .3s ease,border-color .3s ease;">
    <div style="max-width:1220px;margin:0 auto;padding:14px clamp(20px,5vw,40px);display:flex;align-items:center;justify-content:space-between;gap:20px;">
      <a href="#top" aria-label="Neptor Systems — inicio" style="display:flex;align-items:center;flex-shrink:0;">
        <img data-logo src="/assets/logo-neptor-white.png" alt="Neptor Systems" width="150" height="36" style="height:36px;width:auto;display:block;" />
      </a>
      <nav data-nav-links aria-label={lang === 'es' ? 'Navegación principal' : 'Main navigation'} style="display:flex;align-items:center;gap:6px;">
        <a data-navlink href="#que-es" style="font-family:var(--font-ui);font-size:15px;font-weight:500;color:rgba(255,255,255,0.85);padding:8px 14px;border-radius:999px;transition:color .25s ease,background .25s ease;">{t.nav1}</a>
        <a data-navlink href="#como-funciona" style="font-family:var(--font-ui);font-size:15px;font-weight:500;color:rgba(255,255,255,0.85);padding:8px 14px;border-radius:999px;transition:color .25s ease,background .25s ease;">{t.howItWorks}</a>
        <a data-navlink href="#estado" style="font-family:var(--font-ui);font-size:15px;font-weight:500;color:rgba(255,255,255,0.85);padding:8px 14px;border-radius:999px;transition:color .25s ease,background .25s ease;">{t.nav3}</a>
        <a data-navlink href="#colabora" style="font-family:var(--font-ui);font-size:15px;font-weight:500;color:rgba(255,255,255,0.85);padding:8px 14px;border-radius:999px;transition:color .25s ease,background .25s ease;">{t.nav4}</a>
      </nav>
      <div style="display:flex;align-items:center;gap:14px;flex-shrink:0;">
        <div role="group" aria-label="Idioma / Language" style="display:flex;align-items:center;gap:2px;">
          <a data-langlink="es" href={ALT.home.es} hreflang="es" aria-current={lang === 'es' ? 'true' : undefined} aria-label="Español" style={`text-decoration:none;font-family:var(--font-ui);font-size:13px;font-weight:${lang === 'es' ? '700' : '500'};letter-spacing:0.04em;padding:6px 6px;border-radius:8px;color:${lang === 'es' ? '#fff' : 'rgba(255,255,255,0.6)'};transition:color .25s ease;`}>ES</a>
          <span data-langsep aria-hidden="true" style="color:rgba(255,255,255,0.35);font-family:var(--font-ui);font-size:12px;">|</span>
          <a data-langlink="en" href={ALT.home.en} hreflang="en" aria-current={lang === 'en' ? 'true' : undefined} aria-label="English" style={`text-decoration:none;font-family:var(--font-ui);font-size:13px;font-weight:${lang === 'en' ? '700' : '500'};letter-spacing:0.04em;padding:6px 6px;border-radius:8px;color:${lang === 'en' ? '#fff' : 'rgba(255,255,255,0.6)'};transition:color .25s ease;`}>EN</a>
        </div>
        <a class="btn btn--gold btn--sm" href="#colabora">{t.navCta}</a>
      </div>
    </div>
  </header>

  <!-- Depth rail (desktop) -->
  <nav data-rail aria-label={lang === 'es' ? 'Progreso de la página' : 'Page progress'} style="position:fixed;right:22px;top:50%;transform:translateY(-50%);z-index:55;display:flex;flex-direction:column;gap:14px;align-items:center;">
    <a data-raildot href="#top" aria-label={lang === 'es' ? 'Inicio' : 'Home'} style="display:block;width:8px;height:8px;border-radius:999px;background:rgba(0,194,209,0.35);transition:all .3s ease;"></a>
    <a data-raildot href="#que-es" aria-label={t.nav1} style="display:block;width:8px;height:8px;border-radius:999px;background:rgba(0,194,209,0.35);transition:all .3s ease;"></a>
    <a data-raildot href="#solucion" aria-label={t.s4Kicker} style="display:block;width:8px;height:8px;border-radius:999px;background:rgba(0,194,209,0.35);transition:all .3s ease;"></a>
    <a data-raildot href="#como-funciona" aria-label={t.howItWorks} style="display:block;width:8px;height:8px;border-radius:999px;background:rgba(0,194,209,0.35);transition:all .3s ease;"></a>
    <a data-raildot href="#estado" aria-label={t.nav3} style="display:block;width:8px;height:8px;border-radius:999px;background:rgba(0,194,209,0.35);transition:all .3s ease;"></a>
    <a data-raildot href="#colabora" aria-label={t.nav4} style="display:block;width:8px;height:8px;border-radius:999px;background:rgba(0,194,209,0.35);transition:all .3s ease;"></a>
  </nav>

  <main id="main">

  <!-- ============ S1 · HERO ============ -->
  <section data-hero style="position:relative;overflow:hidden;background:linear-gradient(180deg,var(--navy-900) 0%,var(--navy-800) 62%,#0C2450 100%);">
    <div aria-hidden="true" style="position:absolute;inset:0;background:radial-gradient(90% 70% at 78% -10%, rgba(0,194,209,0.24) 0%, rgba(0,194,209,0) 55%), radial-gradient(60% 50% at 8% 108%, rgba(0,194,209,0.10) 0%, rgba(0,194,209,0) 60%);"></div>
    <div aria-hidden="true" style="position:absolute;inset:0;overflow:hidden;pointer-events:none;"><div data-amb style="position:absolute;inset:-25%;background:radial-gradient(45% 38% at 30% 42%, rgba(0,194,209,0.20) 0%, rgba(0,194,209,0) 70%);animation:neptorGlowDrift 15s ease-in-out infinite;"></div><div data-amb style="position:absolute;inset:-25%;background:radial-gradient(40% 34% at 70% 30%, rgba(0,194,209,0.16) 0%, rgba(0,194,209,0) 72%);animation:neptorGlowDrift 16.5s ease-in-out infinite reverse;"></div><div data-bubblefield aria-hidden="true" style="position:absolute;inset:0;"></div></div>
    <div style="position:relative;max-width:1220px;margin:0 auto;padding:clamp(136px,17vw,184px) clamp(20px,5vw,40px) clamp(140px,15vw,180px);">
      <div data-hero-grid style="display:grid;grid-template-columns:1.02fr 0.98fr;gap:clamp(40px,6vw,88px);align-items:center;">
        <div>
          <div data-hs style="display:inline-flex;align-items:center;gap:10px;border:1px solid rgba(0,194,209,0.35);background:rgba(0,194,209,0.08);border-radius:999px;padding:8px 16px;">
            <span data-pulse aria-hidden="true" style="width:7px;height:7px;border-radius:999px;background:var(--aqua-500);box-shadow:0 0 0 3px rgba(0,194,209,0.18);animation:neptorPulse 2.8s ease-in-out infinite;"></span>
            <span style="font-family:var(--font-ui);font-size:12px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:var(--aqua-300);">{t.eyebrow}</span>
          </div>
          <h1 data-hs style="font-family:var(--font-heading);font-weight:700;font-size:clamp(2.5rem,5.4vw,4.15rem);line-height:1.03;letter-spacing:-0.025em;color:#fff;margin:26px 0 0;text-wrap:balance;">{t.h1a} <span style="position:relative;display:inline-block;white-space:nowrap;">{t.h1b}<svg aria-hidden="true" viewBox="0 0 220 14" preserveAspectRatio="none" style="position:absolute;left:0;right:0;bottom:-8px;width:100%;height:12px;"><path data-h1wave d="M3,8 C33,2 55,2 85,8 S140,14 170,8 S205,3 217,6" fill="none" stroke="var(--aqua-500)" stroke-width="2.5" stroke-linecap="round" vector-effect="non-scaling-stroke" opacity="0.9"/></svg></span></h1>
          <p data-hs style="font-family:var(--font-body);font-size:clamp(1.06rem,1.7vw,1.28rem);line-height:1.6;color:rgba(255,255,255,0.74);max-width:540px;margin:26px 0 0;text-wrap:pretty;">{t.heroSub}</p>
          <div data-hs style="display:flex;flex-wrap:wrap;gap:14px;margin-top:38px;">
            <a class="btn btn--gold btn--lg" href="#colabora">{t.ctaJoin}</a>
            <a class="btn btn--secondary btn--on-dark btn--lg" href="#colabora">{t.ctaCollab}</a>
          </div>
          <p data-hs style="font-family:var(--font-ui);font-size:14px;line-height:1.5;color:rgba(255,255,255,0.5);margin:22px 0 0;">{t.micro}</p>
          <div data-hs style="display:flex;flex-wrap:wrap;gap:10px;margin-top:22px;">
            {[t.chipRD, t.chipProto, t.chipMurcia].map((c) => (
              <span style="font-family:var(--font-ui);font-size:13px;font-weight:500;color:rgba(255,255,255,0.82);border:1px solid rgba(255,255,255,0.22);background:rgba(255,255,255,0.05);border-radius:999px;padding:7px 15px;">{c}</span>
            ))}
          </div>
        </div>
        <div data-hero-visual data-hs style="position:relative;width:100%;">
          <div data-hero-photo style="position:relative;width:92%;margin-left:auto;aspect-ratio:4/3;border-radius:22px;overflow:hidden;border:1px solid rgba(255,255,255,0.16);box-shadow:0 50px 90px -40px rgba(0,0,0,0.65);">
            <ImageSlot alt={heroAlt} name="hero" priority={true} radius="22px" sizes="(max-width: 960px) 90vw, 520px" />
          </div>
          <div data-levit style="position:absolute;left:-8px;bottom:-34px;max-width:320px;background:#fff;border:1px solid var(--line-200);border-radius:18px;box-shadow:0 30px 60px -24px rgba(10,31,68,0.45);padding:20px 22px 16px;animation:neptorLevit 7s ease-in-out infinite;">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:6px;">
              <div style="display:flex;flex-direction:column;align-items:center;gap:6px;">
                <svg width="52" height="52" viewBox="0 0 132 132" fill="none" stroke="var(--navy-800)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><ellipse cx="66" cy="66" rx="46" ry="34"/><ellipse cx="66" cy="66" rx="30" ry="20" stroke="var(--aqua-500)"/></svg>
                <span style="font-family:var(--font-ui);font-size:11px;font-weight:600;color:var(--navy-800);">{t.wristband}</span>
              </div>
              <svg width="70" height="26" viewBox="0 0 70 26" fill="none" aria-hidden="true" style="margin-bottom:16px;">
                <path d="M4,13 C14,6 21,6 31,13 S52,20 66,11" stroke="var(--line-200)" stroke-width="1.5" stroke-linecap="round"/>
                <path data-signal d="M4,13 C14,6 21,6 31,13 S52,20 66,11" stroke="var(--aqua-500)" stroke-width="1.75" stroke-linecap="round" stroke-dasharray="7 13" style="animation:neptorSignal 3.2s linear infinite;"/>
              </svg>
              <div style="display:flex;flex-direction:column;align-items:center;gap:6px;">
                <svg width="52" height="52" viewBox="0 0 132 132" fill="none" stroke="var(--navy-800)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="34" y="38" width="64" height="58" rx="16"/><line x1="46" y1="106" x2="86" y2="106" stroke="var(--aqua-500)"/></svg>
                <span style="font-family:var(--font-ui);font-size:11px;font-weight:600;color:var(--navy-800);">{t.hub}</span>
              </div>
            </div>
            <div style="border-top:1px solid var(--line-100);margin-top:14px;padding-top:10px;text-align:center;font-family:var(--font-ui);font-size:10px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink-400);">{t.conceptual}</div>
          </div>
        </div>
      </div>
      <div data-nudge aria-hidden="true" style="position:absolute;left:50%;bottom:26px;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:6px;color:rgba(255,255,255,0.45);animation:neptorNudge 2.6s ease-in-out infinite;">
        <span style="width:1px;height:34px;background:linear-gradient(180deg,rgba(255,255,255,0) 0%,rgba(0,194,209,0.7) 100%);"></span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--aqua-300)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
    </div>
    <div aria-hidden="true" style="position:absolute;left:0;right:0;bottom:0;height:110px;overflow:hidden;pointer-events:none;">
      <div data-wave-anim style="position:absolute;bottom:26px;left:0;width:200%;height:64px;animation:neptorWaveDrift 34s linear infinite;">
        <svg viewBox="0 0 2880 60" preserveAspectRatio="none" style="width:100%;height:100%;display:block;"><path d="M0,30 C120,10 240,10 360,30 S600,50 720,30 S960,10 1080,30 S1320,50 1440,30 S1680,10 1800,30 S2040,50 2160,30 S2400,10 2520,30 S2760,50 2880,30" fill="none" stroke="var(--aqua-500)" stroke-width="1.5" vector-effect="non-scaling-stroke" opacity="0.5"/></svg>
      </div>
      <div data-wave-anim style="position:absolute;bottom:12px;left:0;width:200%;height:64px;animation:neptorWaveDrift 48s linear infinite;">
        <svg viewBox="0 0 2880 60" preserveAspectRatio="none" style="width:100%;height:100%;display:block;"><path d="M0,30 C120,10 240,10 360,30 S600,50 720,30 S960,10 1080,30 S1320,50 1440,30 S1680,10 1800,30 S2040,50 2160,30 S2400,10 2520,30 S2760,50 2880,30" fill="none" stroke="var(--aqua-300)" stroke-width="1.5" vector-effect="non-scaling-stroke" opacity="0.3"/></svg>
      </div>
      <div data-wave-anim style="position:absolute;bottom:0;left:0;width:200%;height:64px;animation:neptorWaveDrift 62s linear infinite;">
        <svg viewBox="0 0 2880 60" preserveAspectRatio="none" style="width:100%;height:100%;display:block;"><path d="M0,30 C120,10 240,10 360,30 S600,50 720,30 S960,10 1080,30 S1320,50 1440,30 S1680,10 1800,30 S2040,50 2160,30 S2400,10 2520,30 S2760,50 2880,30" fill="none" stroke="#fff" stroke-width="1" vector-effect="non-scaling-stroke" opacity="0.14"/></svg>
      </div>
    </div>
  </section>

  <!-- ============ S2 · NEPTOR EN UNA PÁGINA ============ -->
  <section id="que-es" style="background:#fff;scroll-margin-top:92px;">
    <div style="max-width:1220px;margin:0 auto;padding:clamp(88px,11vw,128px) clamp(20px,5vw,40px);">
      <div data-s2 style="display:grid;grid-template-columns:5fr 7fr;gap:clamp(40px,6vw,88px);align-items:start;">
        <div data-s2-intro data-rv data-rv-self style="position:sticky;top:120px;">
          <div style="font-family:var(--font-ui);font-size:12px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:var(--aqua-700);">{t.s2Kicker}</div>
          <h2 style="font-family:var(--font-heading);font-weight:700;font-size:clamp(1.9rem,3.4vw,2.5rem);line-height:1.12;letter-spacing:-0.02em;color:var(--navy-800);margin:14px 0 0;text-wrap:balance;">{t.missionTagline}</h2>
          <p style="font-family:var(--font-heading);font-weight:500;font-size:clamp(1.3rem,2.2vw,1.7rem);line-height:1.4;letter-spacing:-0.01em;color:var(--navy-800);margin:18px 0 0;text-wrap:pretty;"><strong style="font-weight:700;">Neptor Systems</strong>{t.s2Intro1}</p>
          <p style="font-family:var(--font-body);font-size:17px;line-height:1.7;color:var(--ink-500);margin:18px 0 0;text-wrap:pretty;">{t.s2Intro2}</p>
        </div>
        <div data-rv data-hcards style="display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:22px;align-items:start;">
          <div>
            <div class="card" style="height:100%;">
              <div style="color:var(--aqua-300);width:52px;height:52px;border-radius:14px;background:var(--navy-800);display:flex;align-items:center;justify-content:center;"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="2"/><path d="M4.9 4.9a10 10 0 0 0 0 14.2M19.1 4.9a10 10 0 0 1 0 14.2M7.8 7.8a6 6 0 0 0 0 8.4M16.2 7.8a6 6 0 0 1 0 8.4"/></svg></div>
              <h3 style="font-family:var(--font-heading);font-weight:600;font-size:20px;color:var(--navy-800);margin:18px 0 8px;">{t.card1T}</h3>
              <p style="font-family:var(--font-body);font-size:16px;line-height:1.62;color:var(--ink-500);margin:0;">{t.card1}</p>
            </div>
          </div>
          <div data-stagger style="margin-top:36px;">
            <div class="card" style="height:100%;">
              <div style="color:var(--aqua-300);width:52px;height:52px;border-radius:14px;background:var(--navy-800);display:flex;align-items:center;justify-content:center;"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg></div>
              <h3 style="font-family:var(--font-heading);font-weight:600;font-size:20px;color:var(--navy-800);margin:18px 0 8px;">{t.card2T}</h3>
              <p style="font-family:var(--font-body);font-size:16px;line-height:1.62;color:var(--ink-500);margin:0;">{t.card2}</p>
            </div>
          </div>
          <div>
            <div class="card" style="height:100%;">
              <div style="color:var(--aqua-300);width:52px;height:52px;border-radius:14px;background:var(--navy-800);display:flex;align-items:center;justify-content:center;"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
              <h3 style="font-family:var(--font-heading);font-weight:600;font-size:20px;color:var(--navy-800);margin:18px 0 8px;">{t.card3T}</h3>
              <p style="font-family:var(--font-body);font-size:16px;line-height:1.62;color:var(--ink-500);margin:0;">{t.card3}</p>
            </div>
          </div>
          <div data-stagger style="margin-top:36px;">
            <div class="card" style="height:100%;">
              <div style="color:var(--aqua-300);width:52px;height:52px;border-radius:14px;background:var(--navy-800);display:flex;align-items:center;justify-content:center;"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
              <h3 style="font-family:var(--font-heading);font-weight:600;font-size:20px;color:var(--navy-800);margin:18px 0 8px;">{t.card4T}</h3>
              <p style="font-family:var(--font-body);font-size:16px;line-height:1.62;color:var(--ink-500);margin:0;">{t.card4}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ S3 · EL PROBLEMA ============ -->
  <section style="background:var(--aqua-050);border-top:1px solid var(--aqua-100);border-bottom:1px solid var(--aqua-100);position:relative;overflow:hidden;">
    <svg aria-hidden="true" viewBox="0 0 1440 60" preserveAspectRatio="none" style="position:absolute;top:52%;left:0;width:100%;height:60px;opacity:0.35;"><path d="M0,30 C180,8 360,8 540,30 S900,52 1080,30 S1350,10 1440,26" fill="none" stroke="var(--aqua-300)" stroke-width="1.5" vector-effect="non-scaling-stroke"/></svg>
    <div data-rv style="position:relative;max-width:1220px;margin:0 auto;padding:clamp(88px,11vw,128px) clamp(20px,5vw,40px);">
      <div style="font-family:var(--font-ui);font-size:12px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:var(--aqua-700);">{t.s3Kicker}</div>
      <h2 style="font-family:var(--font-heading);font-weight:600;font-size:clamp(2rem,3.8vw,2.75rem);line-height:1.1;letter-spacing:-0.015em;color:var(--navy-800);margin:16px 0 0;max-width:17ch;text-wrap:balance;">{t.s3H2}</h2>
      <div data-s3 style="display:grid;grid-template-columns:7fr 5fr;gap:clamp(36px,6vw,72px);margin-top:clamp(44px,6vw,64px);align-items:end;">
        <div>
          <div data-count style="font-family:var(--font-heading);font-weight:700;font-size:clamp(4rem,9.5vw,7.75rem);line-height:0.95;letter-spacing:-0.035em;color:var(--navy-800);font-variant-numeric:tabular-nums;">{t.statNum}</div>
          <p style="font-family:var(--font-ui);font-size:clamp(1.05rem,1.6vw,1.25rem);font-weight:600;line-height:1.45;color:var(--navy-800);margin:22px 0 0;max-width:560px;">{t.statStrong}</p>
          <p style="font-family:var(--font-body);font-size:16px;line-height:1.6;color:var(--ink-500);margin:10px 0 0;max-width:560px;">{t.statSub}</p>
          <p style="font-family:var(--font-body);font-size:13px;line-height:1.5;color:var(--ink-400);margin:22px 0 0;">{t.source}</p>
