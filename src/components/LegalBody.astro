---
import { dict, type Lang } from '../i18n/copy';
import { ALT, LEGAL, ORG } from '../config';
import type { PageId } from '../config';

interface Props { lang: Lang; pageId: Exclude<PageId, 'home'>; title: string }
const { lang, pageId, title } = Astro.props;
const es = lang === 'es';
const t = dict[lang];
const legal = LEGAL[lang];
const home = ALT.home[lang];
const mailto = `mailto:${ORG.email}`;
const backLabel = es ? 'Volver al inicio' : 'Back to home';

const countryName = es ? 'España' : 'Spain';
const fullAddress = `${ORG.streetAddress}, ${ORG.postalCode} ${ORG.addressLocality}, ${ORG.addressRegion}, ${countryName}`;

// Corporate identification rows (Aviso legal / Legal notice)
const idLabels = es
  ? { ident: 'Identificación de la empresa', name: 'Denominación social', nif: 'NIF', office: 'Domicilio social', email: 'Correo electrónico', phone: 'Teléfono' }
  : { ident: 'Company identification', name: 'Company name', nif: 'Tax ID (NIF)', office: 'Registered office', email: 'Email', phone: 'Phone' };
const idRows = [
  { label: idLabels.name, value: ORG.name },
  { label: idLabels.nif, value: ORG.vatID },
  { label: idLabels.office, value: fullAddress },
  { label: idLabels.email, value: ORG.email, href: mailto },
  { label: idLabels.phone, value: ORG.phone, href: `tel:${ORG.phoneHref}` },
];

// Per-page body copy (concise, factual — no legal drafting)
const contactLabel = es ? 'Contacto' : 'Contact';
const bodies: Record<string, { intro: string; paras: string[] }> = es
  ? {
      legal: {
        intro: 'Datos identificativos del titular de este sitio web, conforme a la normativa vigente.',
        paras: ['Para cualquier cuestión legal relacionada con este sitio web, utiliza el correo de contacto.'],
      },
      privacy: {
        intro: 'Cómo tratamos tus datos en Neptor Systems.',
        paras: [
          'Este sitio web es informativo y no utiliza cookies de seguimiento, publicidad ni herramientas de analítica de terceros.',
          'Solo tratamos los datos que nos facilitas voluntariamente —por ejemplo, si te unes a la lista de espera o nos escribes— con la finalidad de responderte e informarte sobre el desarrollo del proyecto. No cedemos tus datos a terceros.',
          'Puedes ejercer tus derechos de acceso, rectificación o supresión a través del correo de contacto.',
        ],
      },
      cookies: {
        intro: 'Uso de cookies en este sitio web.',
        paras: [
          'Este sitio web no utiliza cookies de terceros, de analítica ni de publicidad, y no realiza seguimiento de tu navegación.',
          'Únicamente podrían emplearse almacenamientos técnicos imprescindibles para el correcto funcionamiento de la página.',
          'Si tienes cualquier duda, utiliza el correo de contacto.',
        ],
      },
    }
  : {
      legal: {
        intro: 'Identifying details of the owner of this website, in accordance with applicable regulations.',
        paras: ['For any legal matter regarding this website, please use the contact email.'],
      },
      privacy: {
        intro: 'How we handle your data at Neptor Systems.',
        paras: [
          'This website is informational and uses no tracking, advertising or third-party analytics cookies.',
          'We only process the data you voluntarily provide —for example, if you join the waitlist or contact us— in order to reply and keep you informed about the project’s development. We do not share your data with third parties.',
          'You can exercise your rights of access, rectification or erasure through the contact email.',
        ],
      },
      cookies: {
        intro: 'Use of cookies on this website.',
        paras: [
          'This website uses no third-party, analytics or advertising cookies, and does not track your browsing.',
          'Only technical storage strictly necessary for the page to function may be used.',
          'If you have any questions, please use the contact email.',
        ],
      },
    };
const body = bodies[pageId];
const isLegalNotice = pageId === 'legal';
---
<a class="skip-link" href="#main">{es ? 'Saltar al contenido' : 'Skip to content'}</a>

<header style="background:var(--navy-900);">
  <div style="max-width:900px;margin:0 auto;padding:18px clamp(20px,5vw,40px);display:flex;align-items:center;justify-content:space-between;gap:20px;">
    <a href={home} aria-label="Neptor Systems — inicio" style="display:flex;align-items:center;">
      <img src="/assets/logo-neptor-white.png" alt="Neptor Systems" width="150" height="34" style="height:34px;width:auto;display:block;" />
    </a>
    <a href={home} style="font-family:var(--font-ui);font-size:14px;font-weight:600;color:rgba(255,255,255,0.85);">← {backLabel}</a>
  </div>
</header>

<main id="main" style="min-height:60vh;">
  <div style="max-width:760px;margin:0 auto;padding:clamp(56px,9vw,96px) clamp(20px,5vw,40px);">
    <div style="font-family:var(--font-ui);font-size:12px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:var(--aqua-700);">{ORG.name}</div>
    <h1 style="font-family:var(--font-heading);font-weight:700;font-size:clamp(2rem,4vw,2.75rem);line-height:1.1;letter-spacing:-0.02em;color:var(--navy-800);margin:14px 0 0;">{title}</h1>
    <p style="font-family:var(--font-body);font-size:17px;line-height:1.6;color:var(--ink-500);margin:16px 0 0;">{body.intro}</p>

    {isLegalNotice && (
      <section aria-label={idLabels.ident} style="margin-top:clamp(32px,5vw,48px);padding:clamp(28px,4vw,40px);background:#fff;border:1px solid var(--line-200);border-radius:18px;box-shadow:var(--shadow-sm);">
        <h2 style="font-family:var(--font-heading);font-weight:600;font-size:20px;color:var(--navy-800);margin:0 0 18px;">{idLabels.ident}</h2>
        <dl style="margin:0;display:grid;grid-template-columns:1fr;gap:14px;">
          {idRows.map((r) => (
            <div class="legal-id-row">
              <dt style="font-family:var(--font-ui);font-size:12px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;color:var(--ink-400);">{r.label}</dt>
              <dd style="margin:0;font-family:var(--font-body);font-size:16px;line-height:1.5;color:var(--ink-700);">
                {r.href ? <a href={r.href} style="color:var(--aqua-700);">{r.value}</a> : r.value}
              </dd>
            </div>
          ))}
        </dl>
      </section>
    )}

    <div style="margin-top:clamp(28px,4vw,40px);">
      {body.paras.map((p) => (
        <p style="font-family:var(--font-body);font-size:17px;line-height:1.7;color:var(--ink-700);margin:0 0 16px;">{p}</p>
      ))}
      <p style="font-family:var(--font-body);font-size:16px;line-height:1.6;color:var(--ink-500);margin:20px 0 0;">
        {contactLabel}: <a href={mailto} style="color:var(--aqua-700);">{ORG.email}</a>
      </p>
    </div>
  </div>
</main>

<footer style="background:var(--navy-900);color:#fff;">
  <div style="max-width:900px;margin:0 auto;padding:40px clamp(20px,5vw,40px);">
    <div style="display:flex;flex-wrap:wrap;gap:8px 16px;align-items:center;">
      <a href={legal.legal} style="font-family:var(--font-ui);font-size:14px;color:rgba(255,255,255,0.7);">{t.ftLegal}</a>
      <span style="color:rgba(255,255,255,0.25);">·</span>
      <a href={legal.privacy} style="font-family:var(--font-ui);font-size:14px;color:rgba(255,255,255,0.7);">{t.ftPrivacy}</a>
      <span style="color:rgba(255,255,255,0.25);">·</span>
      <a href={legal.cookies} style="font-family:var(--font-ui);font-size:14px;color:rgba(255,255,255,0.7);">{t.ftCookies}</a>
      <span style="color:rgba(255,255,255,0.25);">·</span>
      <a href={mailto} style="font-family:var(--font-ui);font-size:14px;color:rgba(255,255,255,0.7);">{ORG.email}</a>
    </div>
    <p style="font-family:var(--font-ui);font-size:13px;color:rgba(255,255,255,0.4);margin:20px 0 0;">© 2026 Neptor Systems SL</p>
  </div>
</footer>
