---
import { dict, type Lang } from '../i18n/copy';
import { ALT, LEGAL, ORG } from '../config';
import type { PageId } from '../config';
import { getLegalDoc, type LegalKey } from '../i18n/legal';

interface Props { lang: Lang; pageId: Exclude<PageId, 'home'>; title: string }
const { lang, pageId, title } = Astro.props;
const es = lang === 'es';
const t = dict[lang];
const legal = LEGAL[lang];
const home = ALT.home[lang];
const mailto = `mailto:${ORG.email}`;
const backLabel = es ? 'Volver al inicio' : 'Back to home';

const doc = getLegalDoc(lang, pageId as LegalKey);

// Inline token map: [[email]] / [[privacy]] / [[aepd]] -> link parts
const tokens: Record<string, { label: string; href: string; external?: boolean }> = {
  email: { label: ORG.email, href: mailto },
  privacy: { label: es ? 'Política de Privacidad' : 'Privacy Policy', href: legal.privacy },
  aepd: { label: 'www.aepd.es', href: 'https://www.aepd.es', external: true },
};
function parts(text: string) {
  return text.split(/(\[\[(?:email|privacy|aepd)\]\])/g).map((seg) => {
    const m = seg.match(/^\[\[(email|privacy|aepd)\]\]$/);
    return m ? { tok: tokens[m[1]] } : { text: seg };
  });
}
---
<a class="skip-link" href="#main">{es ? 'Saltar al contenido' : 'Skip to content'}</a>

<header style="background:var(--navy-900);">
  <div style="max-width:900px;margin:0 auto;padding:18px clamp(20px,5vw,40px);display:flex;align-items:center;justify-content:space-between;gap:20px;">
    <a href={home} aria-label="Neptor Systems — inicio" style="display:flex;align-items:center;">
      <img src="/assets/logo-neptor-white.png" alt="Neptor Systems" width="150" height="34" style="height:34px;width:auto;display:block;" />
    </a>
    <a href={home} style="font-family:var(--font-ui);font-size:14px;font-weight:600;color:rgba(255,255,255,0.85);">← {backLabel}</a>
  </div>
</header>

<main id="main" style="min-height:60vh;">
  <div style="max-width:760px;margin:0 auto;padding:clamp(56px,9vw,96px) clamp(20px,5vw,40px);">
    <div style="font-family:var(--font-ui);font-size:12px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:var(--aqua-700);">{ORG.name}</div>
    <h1 style="font-family:var(--font-heading);font-weight:700;font-size:clamp(2rem,4vw,2.75rem);line-height:1.1;letter-spacing:-0.02em;color:var(--navy-800);margin:14px 0 clamp(28px,4vw,40px);">{title}</h1>

    {doc.sections.map((sec) => (
      <section style="margin-top:clamp(28px,3.5vw,40px);">
        <h2 style="font-family:var(--font-heading);font-weight:600;font-size:clamp(1.2rem,1.9vw,1.4rem);color:var(--navy-800);margin:0 0 12px;">{sec.h2}</h2>
        {sec.blocks.map((b) => (
          <>
            {'p' in b && (
              <p style="font-family:var(--font-body);font-size:16px;line-height:1.7;color:var(--ink-700);margin:0 0 12px;">
                {parts(b.p).map((seg) => (seg.tok
                  ? <a href={seg.tok.href} style="color:var(--aqua-700);" {...(seg.tok.external ? { target: '_blank', rel: 'noopener' } : {})}>{seg.tok.label}</a>
                  : <>{seg.text}</>))}
              </p>
            )}
            {'ul' in b && (
              <ul style="margin:0 0 12px;padding-left:22px;display:flex;flex-direction:column;gap:8px;">
                {b.ul.map((li) => (
                  <li style="font-family:var(--font-body);font-size:16px;line-height:1.6;color:var(--ink-700);">
                    {parts(li).map((seg) => (seg.tok
                      ? <a href={seg.tok.href} style="color:var(--aqua-700);" {...(seg.tok.external ? { target: '_blank', rel: 'noopener' } : {})}>{seg.tok.label}</a>
                      : <>{seg.text}</>))}
                  </li>
                ))}
              </ul>
            )}
            {'defs' in b && (
              <dl style="margin:6px 0 12px;display:grid;grid-template-columns:1fr;gap:12px;">
                {b.defs.map((d) => (
                  <div class="legal-id-row">
                    <dt style="font-family:var(--font-ui);font-size:12px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;color:var(--ink-400);">{d.term}</dt>
                    <dd style="margin:0;font-family:var(--font-body);font-size:16px;line-height:1.5;color:var(--ink-700);">
                      {d.href ? <a href={d.href} style="color:var(--aqua-700);">{d.value}</a> : d.value}
                    </dd>
                  </div>
                ))}
              </dl>
            )}
          </>
        ))}
      </section>
    ))}

    <p style="font-family:var(--font-ui);font-size:13px;color:var(--ink-400);margin:clamp(36px,5vw,48px) 0 0;">{doc.updated}</p>
  </div>
</main>

<footer style="background:var(--navy-900);color:#fff;">
  <div style="max-width:900px;margin:0 auto;padding:40px clamp(20px,5vw,40px);">
    <div style="display:flex;flex-wrap:wrap;gap:8px 16px;align-items:center;">
      <a href={legal.legal} style="font-family:var(--font-ui);font-size:14px;color:rgba(255,255,255,0.7);">{t.ftLegal}</a>
      <span style="color:rgba(255,255,255,0.25);">·</span>
      <a href={legal.privacy} style="font-family:var(--font-ui);font-size:14px;color:rgba(255,255,255,0.7);">{t.ftPrivacy}</a>
      <span style="color:rgba(255,255,255,0.25);">·</span>
      <a href={legal.cookies} style="font-family:var(--font-ui);font-size:14px;color:rgba(255,255,255,0.7);">{t.ftCookies}</a>
      <span style="color:rgba(255,255,255,0.25);">·</span>
      <a href={mailto} style="font-family:var(--font-ui);font-size:14px;color:rgba(255,255,255,0.7);">{ORG.email}</a>
    </div>
    <p style="font-family:var(--font-ui);font-size:13px;color:rgba(255,255,255,0.4);margin:20px 0 0;">© 2026 Neptor Systems SL</p>
  </div>
</footer>
