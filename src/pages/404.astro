---
import '../styles/fonts.css';
import '../styles/tokens.css';
import '../styles/global.css';
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 — Neptor Systems</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <meta name="theme-color" content="#0A1F44" />
  </head>
  <body>
    <main style="min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;background:linear-gradient(180deg,var(--navy-900) 0%,var(--navy-800) 70%,#0C2450 100%);padding:40px 20px;">
      <div style="max-width:520px;">
        <img src="/assets/logo-neptor-white.png" alt="Neptor Systems" width="170" height="40" style="height:40px;width:auto;margin:0 auto;display:block;" />
        <div style="font-family:var(--font-heading);font-weight:700;font-size:clamp(4rem,12vw,6rem);line-height:1;letter-spacing:-0.03em;color:#fff;margin:32px 0 0;">404</div>
        <p style="font-family:var(--font-body);font-size:18px;line-height:1.6;color:rgba(255,255,255,0.78);margin:18px 0 4px;">La página que buscas no existe.</p>
        <p style="font-family:var(--font-body);font-size:18px;line-height:1.6;color:rgba(255,255,255,0.55);margin:0;">The page you are looking for does not exist.</p>
        <div style="display:flex;flex-wrap:wrap;gap:14px;justify-content:center;margin-top:34px;">
          <a class="btn btn--gold btn--lg" href="/">Ir al inicio</a>
          <a class="btn btn--secondary btn--on-dark btn--lg" href="/en/">Go to home</a>
        </div>
      </div>
    </main>
  </body>
</html>
