---
import '../styles/fonts.css';
import '../styles/tokens.css';
import '../styles/global.css';
import { SITE, SEO, ORG, type PageId, ALT } from '../config';
import type { Lang } from '../i18n/copy';

interface Props {
  lang: Lang;
  pageId: PageId;
  /** Override the default per-language SEO title (e.g. legal pages). */
  title?: string;
  /** Override the default per-language SEO description. */
  description?: string;
  /** Emit Organization JSON-LD (home pages only). */
  jsonLd?: boolean;
}

const { lang, pageId, title, description, jsonLd = false } = Astro.props;
const seo = SEO[lang];
const pageTitle = title ?? seo.title;
const pageDesc = description ?? seo.description;

const esUrl = new URL(ALT[pageId].es, SITE).href;
const enUrl = new URL(ALT[pageId].en, SITE).href;
const canonical = new URL(ALT[pageId][lang], SITE).href;
const ogImageUrl = new URL(seo.ogImage, SITE).href;

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: ORG.name,
  url: SITE,
  logo: new URL('/assets/logo-neptor-navy.png', SITE).href,
  email: ORG.email,
  telephone: ORG.phone,
  address: {
    '@type': 'PostalAddress',
    addressLocality: ORG.addressLocality,
    addressCountry: ORG.addressCountry,
  },
};
---
<!doctype html>
<html lang={seo.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={canonical} />

    <!-- hreflang: reciprocal es <-> en + x-default -> es (primary market) -->
    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={esUrl} />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Neptor Systems" />
    <meta property="og:locale" content={seo.locale} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={seo.ogAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Icons + manifest (droplet isotype) -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0A1F44" />

    <!-- Preload the two critical self-hosted faces (H1 + body) -->
    <link rel="preload" href="/fonts/poppins-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-var.woff2" as="font" type="font/woff2" crossorigin />

    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />}

    <!-- Enable JS-gated motion initial states without causing a no-JS FOUC -->
    <script is:inline>document.documentElement.classList.add('js');</script>
  </head>
  <body>
    <slot />
  </body>
</html>
